{
  "name": "@joshuaavalon/eslint-config-javascript",
  "version": "11.0.0",
  "description": "Shareable ESLint JavaScript config.",
  "type": "module",
  "module": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src",
    "prebuild": "rimraf dist",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./deprecated": {
      "import": "./dist/deprecated.js",
      "types": "./dist/deprecated.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    }
  },
  "keywords": [
    "eslint",
    "javascript"
  ],
  "files": [
    "dist"
  ],
  "author": "Joshua Avalon",
  "license": "Apache-2.0",
  "homepage": "https://github.com/joshuaavalon/eslint-config-javascript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshuaavalon/eslint-config-javascript.git",
    "directory": "packages/javascript"
  },
  "bugs": {
    "url": "https://github.com/joshuaavalon/eslint-config-javascript/issues"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.9.0",
    "eslint-plugin-perfectionist": "^5.6.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.2"
  },
  "devDependencies": {
    "@joshuaavalon/eslint-config-javascript": "^10.0.0",
    "@joshuaavalon/eslint-config-typescript": "^10.0.0",
    "@typescript-eslint/utils": "^8.46.1",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
